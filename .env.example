# ── App ───────────────────────────────────────────────
PORT=3000
# Public base URL used to build image `url` in responses
PUBLIC_BASE_URL=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────
DB_HOST=localhost
# Host port for the Dockerised DB. Default 5433 avoids clashing with a
# locally-installed PostgreSQL on 5432. Inside docker-compose the API uses 5432.
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=images
# Auto-create schema from entities. true for dev only — use migrations in prod.
DB_SYNCHRONIZE=true

# ── Storage ───────────────────────────────────────────
# Local filesystem directory where processed images are stored
STORAGE_DIR=./storage

# ── Upload / image limits (security) ──────────────────
# Max upload size in bytes (5 MB)
MAX_FILE_SIZE=5242880
# Max width/height allowed for resize (anti image-bomb)
MAX_IMAGE_DIMENSION=4000

# ── Rate limiting ─────────────────────────────────────
# Requests per TTL window (seconds)
THROTTLE_TTL=60
THROTTLE_LIMIT=60
